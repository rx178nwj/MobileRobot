                <mxCell id="flow_text" value="&lt;b&gt;Sensor Input&lt;/b&gt;&lt;br&gt;• YDLIDAR T-mini → /scan  (BEST_EFFORT, 10Hz, 360°)&lt;br&gt;• IMX708 → camera_service :8003 → ws_camera_bridge&lt;br&gt;  → /camera/image_raw/compressed&lt;br&gt;  → image_decompress → /camera/image_raw&lt;br&gt;• PR2040 encoders → odom_service :8002 → ws_odom_pub&lt;br&gt;  → /odom  +  TF(odom → base_footprint)&lt;br&gt;&lt;br&gt;&lt;b&gt;SLAM (2D LiDAR + Odometry)&lt;/b&gt;&lt;br&gt;• /scan (BEST_EFFORT) + /odom → slam_toolbox&lt;br&gt;• slam_toolbox → /map (OccupancyGrid, 5cm resolution)&lt;br&gt;• slam_toolbox → TF(map → odom)&lt;br&gt;• lifecycle_manager_slam activates node (bond_timeout=0)&lt;br&gt;&lt;br&gt;&lt;b&gt;Navigation&lt;/b&gt;&lt;br&gt;• /map + /goal_pose → bt_navigator → controller_server&lt;br&gt;• controller_server → /cmd_vel_nav&lt;br&gt;• velocity_smoother → /cmd_vel_smoothed&lt;br&gt;• collision_monitor (/scan, min_range 0.15m) → /cmd_vel&lt;br&gt;&lt;br&gt;&lt;b&gt;Autonomous Mapping&lt;/b&gt;&lt;br&gt;• /map frontier detection → /navigate_to_pose action&lt;br&gt;• /mapping/status (coverage%, stuck_timeout=60s)&lt;br&gt;&lt;br&gt;&lt;b&gt;AI Navigation Pipeline (YOLO + Ollama)&lt;/b&gt;&lt;br&gt;• /camera/image_raw → YOLO yolov8s.pt (RTX 4060)&lt;br&gt;  → scene text: "person (center,far), chair (left,close)"&lt;br&gt;• scene text + /llm_command → Ollama qwen3.5:9b&lt;br&gt;  → localhost:11434/v1 (no cloud, fully local)&lt;br&gt;• JSON {action} → /cmd_vel or /goal_pose&lt;br&gt;&lt;br&gt;&lt;b&gt;Motor Output&lt;/b&gt;&lt;br&gt;• /cmd_vel → ws_motor_controller → WS :8001&lt;br&gt;• → motor_service → PR2040 PWM L/R" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1068" y="110" width="540" height="315" as="geometry"/>
                </mxCell>

                <!-- TF Tree -->
                <mxCell id="tf_frame" value="TF Tree" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontColor=#333;fontSize=12;fontStyle=1;verticalAlign=top;align=center;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="450" width="260" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="tf_text" value="map&lt;br&gt; └─ odom  &lt;i&gt;(slam_toolbox)&lt;/i&gt;&lt;br&gt;     └─ base_footprint  &lt;i&gt;(ws_odom_pub)&lt;/i&gt;&lt;br&gt;          └─ base_link  &lt;i&gt;(robot_state_pub)&lt;/i&gt;&lt;br&gt;               └─ laser_frame  &lt;i&gt;(robot_state_pub)&lt;/i&gt;&lt;br&gt;               └─ camera_optical_frame  &lt;i&gt;(rsp)&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;" parent="1" vertex="1">
